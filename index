<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI-Native PM Readiness Assessment</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #06070d;
      --surface:   rgba(255,255,255,0.04);
      --surface-h: rgba(255,255,255,0.07);
      --border:    rgba(255,255,255,0.08);
      --primary:   #6366f1;
      --secondary: #ec4899;
      --text:      #f8fafc;
      --muted:     #94a3b8;
      --subtle:    #334155;
      --d1: #6366f1; --d2: #a855f7; --d3: #06b6d4;
      --d4: #f59e0b; --d5: #10b981; --d6: #ec4899;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── Background orbs ── */
    .bg-orb {
      position: fixed; border-radius: 50%;
      filter: blur(120px); pointer-events: none; z-index: 0;
      animation: orb-drift 18s ease-in-out infinite alternate;
    }
    .orb1 { width:520px; height:520px; background:rgba(99,102,241,.18); top:-180px; left:-160px; }
    .orb2 { width:400px; height:400px; background:rgba(236,72,153,.14); bottom:-120px; right:-100px; animation-delay:-9s; }
    .orb3 { width:260px; height:260px; background:rgba(6,182,212,.10); top:40%; left:55%; animation-delay:-4s; }
    @keyframes orb-drift { from{transform:translate(0,0) scale(1)} to{transform:translate(30px,20px) scale(1.06)} }

    /* ── Wrapper ── */
    #app {
      position: relative; z-index: 1;
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 24px 16px;
    }

    .card {
      width: 100%; max-width: 660px;
      background: rgba(15,17,26,0.82);
      backdrop-filter: blur(24px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 40px 40px 36px;
      box-shadow: 0 32px 80px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.03);
    }
    @media(max-width:520px) { .card{padding:28px 20px 24px;} }

    /* ── Screen transitions ── */
    .screen { animation: fadeUp .45s cubic-bezier(.22,1,.36,1) both; }
    @keyframes fadeUp {
      from { opacity:0; transform:translateY(22px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .screen.exit { animation: fadeDown .28s cubic-bezier(.55,0,1,.45) both; }
    @keyframes fadeDown {
      to { opacity:0; transform:translateY(-16px); }
    }

    /* ── INTRO ── */
    .badge {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase;
      color: var(--primary); background: rgba(99,102,241,.12);
      border: 1px solid rgba(99,102,241,.25); border-radius: 999px;
      padding: 5px 14px; margin-bottom: 24px;
    }
    .badge-dot { width:6px; height:6px; border-radius:50%; background:var(--primary); animation:blink 1.8s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    h1 { font-size: clamp(26px,5vw,36px); font-weight: 800; line-height: 1.15; margin-bottom: 16px; }
    h1 span { background: linear-gradient(135deg,#6366f1,#ec4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }

    .intro-sub { font-size: 15px; color: var(--muted); line-height: 1.65; margin-bottom: 32px; }

    .domain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 32px; }
    @media(max-width:480px) { .domain-grid{grid-template-columns:1fr;} }

    .domain-chip {
      display: flex; align-items: center; gap: 9px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 13px;
      font-size: 12.5px; font-weight: 500; color: var(--muted);
      transition: border-color .2s, background .2s;
    }
    .domain-chip:hover { background: var(--surface-h); border-color: rgba(255,255,255,.14); }
    .domain-chip .dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }

    .meta-row { display: flex; gap: 20px; margin-bottom: 32px; flex-wrap: wrap; }
    .meta-item { display: flex; align-items: center; gap: 7px; font-size: 12.5px; color: var(--muted); }

    .btn-primary {
      display: block; width: 100%; text-align: center;
      background: linear-gradient(135deg, #6366f1, #8b5cf6 50%, #ec4899);
      color: #fff; font-size: 15px; font-weight: 700;
      padding: 15px 28px; border: none; border-radius: 12px; cursor: pointer;
      transition: opacity .2s, transform .15s;
      box-shadow: 0 8px 30px rgba(99,102,241,.35);
    }
    .btn-primary:hover { opacity:.9; transform: translateY(-1px); }
    .btn-primary:active { transform: translateY(0); }

    /* ── QUESTION ── */
    .q-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 28px;
    }
    .q-counter { font-size: 12px; color: var(--muted); font-weight: 600; }

    .progress-track { display: flex; gap: 4px; flex-wrap: wrap; }
    .progress-pip {
      width: 22px; height: 4px; border-radius: 99px; background: var(--border);
      transition: background .3s;
    }
    .progress-pip.done   { background: var(--primary); }
    .progress-pip.active { background: rgba(99,102,241,.5); }

    .scenario {
      font-size: clamp(16px,3.5vw,19px); font-weight: 600; line-height: 1.55;
      margin-bottom: 8px; color: var(--text);
    }
    .scenario-prompt {
      font-size: 13.5px; color: var(--muted); margin-bottom: 26px; line-height:1.5;
    }

    .options { display: flex; flex-direction: column; gap: 10px; }

    .option {
      display: flex; align-items: flex-start; gap: 14px;
      background: var(--surface); border: 1.5px solid var(--border);
      border-radius: 13px; padding: 14px 16px; cursor: pointer;
      transition: border-color .18s, background .18s, transform .18s;
      user-select: none;
    }
    .option:hover { background: var(--surface-h); border-color: rgba(255,255,255,.16); transform: translateX(3px); }
    .option-letter {
      width: 26px; height: 26px; border-radius: 7px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 800; letter-spacing: .04em;
      background: rgba(255,255,255,.06); color: var(--muted);
      transition: background .18s, color .18s;
    }
    .option-text { font-size: 14px; line-height: 1.5; color: var(--text); font-weight: 500; padding-top: 2px; }

    .option.selected { border-color: var(--primary); background: rgba(99,102,241,.1); transform: translateX(3px); }
    .option.selected .option-letter { background: var(--primary); color: #fff; }
    .option.correct-flash { animation: flashGreen .35s ease forwards; }
    @keyframes flashGreen {
      0%   { border-color: var(--primary); background: rgba(99,102,241,.18); }
      50%  { border-color: #10b981;        background: rgba(16,185,129,.18); }
      100% { border-color: var(--primary); background: rgba(99,102,241,.10); }
    }
    .options.disabled .option { cursor: default; pointer-events: none; }

    /* ── RESULTS ── */
    .results-top { text-align: center; margin-bottom: 32px; }
    .archetype-emoji {
      font-size: 56px; display: block; margin-bottom: 12px;
      animation: pop .5s cubic-bezier(.34,1.56,.64,1) .1s both;
    }
    @keyframes pop { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
    .archetype-label { font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase; color: var(--primary); margin-bottom: 10px; }
    .archetype-name  { font-size: clamp(24px,5vw,32px); font-weight: 900; line-height: 1.1; margin-bottom: 10px; }
    .archetype-tagline { font-size: 14.5px; color: var(--muted); line-height: 1.6; }

    .score-ring-wrap { display: flex; justify-content: center; margin: 24px 0 0; }
    .score-ring { position: relative; width: 100px; height: 100px; }
    .score-ring svg { transform: rotate(-90deg); }
    .score-ring-bg   { fill: none; stroke: rgba(255,255,255,.07); stroke-width: 8; }
    .score-ring-fill {
      fill: none; stroke-width: 8; stroke-linecap: round;
      stroke: url(#ring-grad);
      stroke-dasharray: 283; stroke-dashoffset: 283;
      transition: stroke-dashoffset 1.2s cubic-bezier(.22,1,.36,1) .4s;
    }
    .score-ring-text {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .score-ring-num {
      font-size: 24px; font-weight: 800; line-height: 1;
      background: linear-gradient(135deg,#6366f1,#ec4899);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    }
    .score-ring-label { font-size: 9px; color: var(--muted); font-weight: 600; letter-spacing:.06em; text-transform:uppercase; }

    .divider { height: 1px; background: var(--border); margin: 28px 0; }

    .radar-wrap { display: flex; justify-content: center; margin-bottom: 28px; }
    #radarCanvas { max-width: 280px; width: 100%; height: auto; }

    /* domain bars */
    .domain-bars { display: flex; flex-direction: column; gap: 16px; margin-bottom: 28px; }
    .dbar-row { display: flex; align-items: flex-start; gap: 12px; }
    .dbar-icon { font-size: 15px; flex-shrink:0; width:20px; text-align:center; margin-top: 2px; }
    .dbar-info { flex: 1; }
    .dbar-header {
      display: flex; justify-content: space-between; align-items: baseline;
      margin-bottom: 4px;
    }
    .dbar-name { font-size: 13px; font-weight: 700; color: var(--text); }
    .dbar-pct  { font-size: 13px; font-weight: 700; color: var(--text); }
    .dbar-desc { font-size: 11.5px; color: var(--muted); line-height: 1.45; margin-bottom: 7px; }
    .dbar-track { height: 6px; background: rgba(255,255,255,.07); border-radius: 99px; overflow: hidden; }
    .dbar-fill  { height: 100%; border-radius: 99px; width: 0%; transition: width 1s cubic-bezier(.22,1,.36,1) .5s; }
    .dbar-tag {
      display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: .06em;
      padding: 2px 8px; border-radius: 999px; margin-left: 8px;
    }

    .insights-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px; }
    @media(max-width:440px) { .insights-row{grid-template-columns:1fr;} }
    .insight-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 13px; padding: 14px 15px;
    }
    .insight-card-label { font-size: 10px; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
    .insight-card-value { font-size: 13px; font-weight: 600; color: var(--text); line-height: 1.4; }

    .archetype-desc {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 13px; padding: 16px 18px; margin-bottom: 24px;
      font-size: 13.5px; color: var(--muted); line-height: 1.7;
    }
    .archetype-desc strong { color: var(--text); }

    .results-cta {
      background: linear-gradient(135deg,rgba(99,102,241,.15),rgba(236,72,153,.1));
      border: 1px solid rgba(99,102,241,.3); border-radius: 16px;
      padding: 20px 22px; margin-bottom: 24px;
    }
    .results-cta-title { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 5px; }
    .results-cta-sub   { font-size: 12.5px; color: var(--muted); margin-bottom: 16px; line-height:1.5; }
    .btn-cta {
      display: inline-block; text-align: center; width: 100%;
      background: linear-gradient(135deg,#6366f1,#8b5cf6 50%,#ec4899);
      color: #fff; font-size: 14px; font-weight: 700;
      padding: 12px 24px; border: none; border-radius: 10px; cursor: pointer;
      transition: opacity .2s, transform .15s;
      box-shadow: 0 6px 24px rgba(99,102,241,.3);
    }
    .btn-cta:hover { opacity:.9; transform:translateY(-1px); }

    .share-row { display: flex; gap: 8px; margin-bottom: 16px; }
    .btn-share {
      flex: 1; display: flex; align-items: center; justify-content: center; gap: 7px;
      background: var(--surface); border: 1.5px solid var(--border);
      color: var(--muted); font-size: 12px; font-weight: 600;
      padding: 10px; border-radius: 9px; cursor: pointer;
      transition: background .2s, border-color .2s, color .2s;
    }
    .btn-share:hover { background: var(--surface-h); border-color:rgba(255,255,255,.15); color: var(--text); }

    .btn-retake {
      display: block; width: 100%; text-align: center;
      background: none; border: 1.5px solid var(--border);
      color: var(--muted); font-size: 13px; font-weight: 600;
      padding: 11px; border-radius: 10px; cursor: pointer;
      transition: border-color .2s, color .2s;
    }
    .btn-retake:hover { border-color:rgba(255,255,255,.2); color: var(--text); }

    /* toast */
    .toast {
      position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px);
      background: rgba(30,32,44,.96); border: 1px solid var(--border);
      backdrop-filter: blur(20px); border-radius: 10px;
      padding: 11px 20px; font-size: 13px; font-weight: 600; color: var(--text);
      opacity: 0; pointer-events: none; z-index: 999;
      transition: opacity .25s, transform .25s;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  </style>
</head>
<body>
<div class="bg-orb orb1"></div>
<div class="bg-orb orb2"></div>
<div class="bg-orb orb3"></div>
<div id="app"></div>
<div class="toast" id="toast"></div>

<script>
/* ─────────────────────────────────────────────
   DOMAINS
───────────────────────────────────────────── */
const DOMAINS = [
  {
    name:  "AI Technical Intuition",
    icon:  "🧠",
    color: "#6366f1",
    desc:  "How fluently you navigate AI/ML trade-offs — model selection, architecture decisions, and the technical language of AI products — without needing to write the code yourself.",
  },
  {
    name:  "Evaluation & Quality",
    icon:  "🎯",
    color: "#a855f7",
    desc:  "Your ability to define what 'good' looks like for AI outputs, build measurement systems before shipping, and treat quality as a continuous production discipline rather than a pre-launch checklist.",
  },
  {
    name:  "Agentic Workflow Design",
    icon:  "⚡",
    color: "#06b6d4",
    desc:  "How effectively you deploy AI agents to eliminate repetitive work — in your own workflow and in the product — and your architectural instinct for when and how to automate with appropriate guardrails.",
  },
  {
    name:  "Responsible AI Leadership",
    icon:  "🛡️",
    color: "#f59e0b",
    desc:  "Your ownership of the ethical, safety, and regulatory dimensions of AI features — from bias auditing to compliance frameworks — as a product accountability, not a legal handoff.",
  },
  {
    name:  "Applied Prototyping",
    icon:  "🔨",
    color: "#10b981",
    desc:  "Your ability to turn an AI idea into a working, testable artifact — fast — using low/no-code tools, closing the gap between insight and evidence without waiting on engineering sprints.",
  },
  {
    name:  "Strategic AI Judgment",
    icon:  "🗺️",
    color: "#ec4899",
    desc:  "How well you distinguish durable AI product opportunities from temporary advantages, sequence AI bets for compounding value, and make strategic decisions that hold up at the leadership table.",
  },
];

/* ─────────────────────────────────────────────
   QUESTIONS — all options made plausibly credible
   Scores travel with options so shuffling is safe
───────────────────────────────────────────── */
const QUESTIONS = [
  // ── Domain 0: AI Technical Intuition ──
  {
    domain: 0,
    scenario: "Your eng team is split on fine-tuning vs. RAG for your new feature. They want your call.",
    prompt:   "How do you respond?",
    options: [
      { score: 1, text: "Defer to engineering — they have the technical depth to make the right architecture call" },
      { score: 2, text: "Ask them to summarise the trade-offs and come back with a recommendation plus rationale" },
      { score: 3, text: "Drive the conversation by probing data freshness requirements, latency targets, and long-term maintenance overhead" },
      { score: 4, text: "Propose RAG for dynamic data with a clear gate to evaluate fine-tuning once you have real production signal on failure modes" },
    ]
  },
  {
    domain: 0,
    scenario: "A stakeholder insists your team use the latest frontier model for everything — 'to stay cutting edge.'",
    prompt:   "Your move?",
    options: [
      { score: 1, text: "Agree to evaluate it — staying current with top models is a legitimate competitive consideration" },
      { score: 2, text: "Raise the budget implications and ask leadership to weigh in on the cost-versus-value trade-off" },
      { score: 3, text: "Map feature requirements against model capabilities across cost, latency, and context window before committing to anything" },
      { score: 4, text: "Design a routing strategy — premium models on high-stakes reasoning tasks, lighter models elsewhere — and benchmark cost-per-outcome to justify the architecture" },
    ]
  },

  // ── Domain 1: Evaluation & Quality ──
  {
    domain: 1,
    scenario: "Your AI feature has been live for a week. Engineering asks how you know it's working.",
    prompt:   "Your answer is…",
    options: [
      { score: 1, text: "Retention and engagement are up — if users keep using it, it's delivering value" },
      { score: 2, text: "I'm watching feature adoption, session depth, and any friction showing up in support tickets" },
      { score: 3, text: "Task completion rate, user acceptance rate on AI suggestions, and a satisfaction pulse on top of standard product metrics" },
      { score: 4, text: "A pre-built eval pipeline — task success rate, hallucination rate, user acceptance, latency — live before we shipped, with alerting thresholds already set" },
    ]
  },
  {
    domain: 1,
    scenario: "Engineering tells you the model is '90% accurate.' You need to decide whether to ship.",
    prompt:   "Your response?",
    options: [
      { score: 1, text: "90% is solid for an early AI feature — ship it and let real usage tell us where to improve" },
      { score: 2, text: "Ask what the 10% failure scenarios look like and whether there's a graceful fallback in place" },
      { score: 3, text: "Dig into the eval methodology, sample size, and whether 90% holds across the specific edge cases our users are most likely to hit" },
      { score: 4, text: "Run a targeted red-team session to stress-test the failure modes — the distribution of that 10% matters far more than the headline figure" },
    ]
  },

  // ── Domain 2: Agentic Workflows ──
  {
    domain: 2,
    scenario: "Every Monday you spend 90 minutes compiling competitive intel from eight different sources.",
    prompt:   "This Monday…",
    options: [
      { score: 1, text: "I do it manually — competitive awareness is high-leverage work worth the time investment" },
      { score: 2, text: "Batch the sources and use AI to draft the summary, then review and clean it up — cuts it to under 30 minutes" },
      { score: 3, text: "A prompt workflow runs across the sources and outputs a formatted brief; I validate and annotate the final version" },
      { score: 4, text: "A persistent monitoring agent tracks changes continuously and surfaces material shifts as they happen — zero Monday prep time required" },
    ]
  },
  {
    domain: 2,
    scenario: "Your CPO asks whether to build an AI agent for customer onboarding. She wants your view by end of week.",
    prompt:   "You respond with…",
    options: [
      { score: 1, text: "A summary of user research findings and existing friction points, with a recommendation on whether AI adds value" },
      { score: 2, text: "A benchmark of how leading competitors handle onboarding with AI, plus a recommendation based on what's working" },
      { score: 3, text: "A step-by-step breakdown of the onboarding flow — which steps are deterministic enough to automate and which require human judgment — with a proposed handoff model" },
      { score: 4, text: "A scoped agent spec — goals, tools, memory design, escalation triggers, success eval — alongside build/buy/borrow options with risk trade-offs for each" },
    ]
  },

  // ── Domain 3: Responsible AI ──
  {
    domain: 3,
    scenario: "A user reports that your AI recommendation feature appears biased toward certain demographics.",
    prompt:   "Your first move?",
    options: [
      { score: 1, text: "Log the complaint, loop in customer success to understand the scope, and assess impact before deciding on next steps" },
      { score: 2, text: "Escalate immediately to engineering and data science to investigate the model outputs and identify the source" },
      { score: 3, text: "Run a structured bias audit — segment outputs by demographic slice, trace the root cause to training data or model architecture, and own the remediation plan" },
      { score: 4, text: "Pull the fairness monitoring dashboard — it's been running since launch — and either escalate or contain immediately using the pre-prepared response protocol" },
    ]
  },
  {
    domain: 3,
    scenario: "Legal flags the EU AI Act in your product review. Your feature may fall in scope.",
    prompt:   "Your reaction?",
    options: [
      { score: 1, text: "Work closely with legal to understand the specific obligations and what adjustments are needed to the timeline" },
      { score: 2, text: "Research the Act's risk tier framework and identify which category our feature falls under" },
      { score: 3, text: "I've already mapped our AI features to the Act's risk tiers — I know which tier this feature sits in and what that means for documentation and conformity requirements" },
      { score: 4, text: "I have a compliance roadmap already underway — the team is executing on transparency documentation, human oversight mechanisms, and audit trail infrastructure" },
    ]
  },

  // ── Domain 4: Applied Prototyping ──
  {
    domain: 4,
    scenario: "You have a promising AI feature idea you want to validate before committing engineering time to a PRD.",
    prompt:   "What do you do?",
    options: [
      { score: 1, text: "Write up the concept clearly, align with engineering on feasibility, and use that to scope the PRD" },
      { score: 2, text: "Build a high-fidelity Figma prototype that walks stakeholders through the full experience end-to-end" },
      { score: 3, text: "Use a no-code AI platform to build a working demo I can put in front of real users within a couple of days" },
      { score: 4, text: "Have a functional prototype built with an AI API and a lightweight interface tool running by end of day — real users, real feedback, before a single line of production code is written" },
    ]
  },
  {
    domain: 4,
    scenario: "Your CEO wants to see the AI assistant concept live and interactive — by tomorrow morning.",
    prompt:   "You…",
    options: [
      { score: 1, text: "Coordinate with engineering for a rapid scoped demo — cut features to make it work in the time available" },
      { score: 2, text: "Put together a high-fidelity Figma prototype that accurately simulates the full interaction flow" },
      { score: 3, text: "Use a no-code AI builder to get something genuinely interactive into the CEO's hands tonight" },
      { score: 4, text: "Send over the URL for the prototype that's already deployed — and bring fresh user feedback data to the meeting" },
    ]
  },

  // ── Domain 5: Strategic AI Judgment ──
  {
    domain: 5,
    scenario: "A key competitor just shipped a well-regarded AI feature in your space and it's generating significant press.",
    prompt:   "Your response?",
    options: [
      { score: 1, text: "Move fast — when competitors are shaping user expectations, speed of response matters as much as quality" },
      { score: 2, text: "Brief the leadership team with a clear breakdown of what was shipped, the likely user impact, and early sentiment" },
      { score: 3, text: "Analyse whether it represents a genuine capability moat or an API wrapper — and identify where our roadmap can leapfrog rather than mirror it" },
      { score: 4, text: "Map the full competitive implications against the roadmap, model the build-versus-leapfrog trade-offs, and deliver a strategic response to leadership within 48 hours" },
    ]
  },
  {
    domain: 5,
