/* ─────────────────────────────────────────────
   SHUFFLE (Fisher-Yates)
───────────────────────────────────────────── */
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

/* ─────────────────────────────────────────────
   SCORING
───────────────────────────────────────────── */
function computeResults() {
  const domainScores = DOMAINS.map((_,di) => {
    const hits = state.answers.filter(a => a.domain === di);
    return hits.reduce((s,a) => s + a.score, 0);
  });
  const totalRaw    = domainScores.reduce((s,v) => s+v, 0);
  const maxPossible = QUESTIONS.length * 4;
  const pct         = totalRaw / maxPossible;
  const archetype   = ARCHETYPES.find(a => pct >= a.range[0] && pct < a.range[1]) || ARCHETYPES[3];
  const domainPcts  = domainScores.map(s => s / 8);
  const maxIdx      = domainPcts.indexOf(Math.max(...domainPcts));
  const minIdx      = domainPcts.indexOf(Math.min(...domainPcts));
  return { domainScores, domainPcts, totalRaw, maxPossible, pct, archetype, maxIdx, minIdx };
}

