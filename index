/* ─────────────────────────────────────────────
   RADAR CHART
───────────────────────────────────────────── */
function drawRadar(scores) {
  const canvas = document.getElementById('radarCanvas');
  if (!canvas) return;
  const ctx    = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W/2, cy = H/2;
  const radius = Math.min(cx, cy) - 54;
  const N      = DOMAINS.length;
  const step   = (Math.PI * 2) / N;
  const start  = -Math.PI / 2;

  function drawGrid() {
    for (let level = 1; level <= 4; level++) {
      ctx.beginPath();
      for (let i = 0; i < N; i++) {
        const a = start + i * step;
        const r = (radius * level) / 4;
        const x = cx + r * Math.cos(a), y = cy + r * Math.sin(a);
        i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
      }
      ctx.closePath();
      ctx.strokeStyle = 'rgba(255,255,255,0.08)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
    for (let i = 0; i < N; i++) {
      const a = start + i * step;
      ctx.beginPath();
      ctx.moveTo(cx, cy);
      ctx.lineTo(cx + radius * Math.cos(a), cy + radius * Math.sin(a));
      ctx.strokeStyle = 'rgba(255,255,255,0.1)';
      ctx.lineWidth = 1;
      ctx.stroke();
    }
  }

  const labelLines = [
    ['Technical','Intuition'], ['Eval &','Quality'], ['Agentic','Workflows'],
    ['Responsible','AI'], ['Applied','Prototyping'], ['Strategic','Judgment'],
  ];

  let progress = 0;
  const animate = () => {
    progress = Math.min(progress + 1/50, 1);
    const ease = 1 - Math.pow(1 - progress, 3);
    ctx.clearRect(0, 0, W, H);
    drawGrid();

    // Filled polygon
    ctx.beginPath();
    for (let i = 0; i < N; i++) {
      const a = start + i * step;
      const r = radius * (scores[i] / 8) * ease;
      const x = cx + r * Math.cos(a), y = cy + r * Math.sin(a);
      i === 0 ? ctx.moveTo(x,y) : ctx.lineTo(x,y);
    }
    ctx.closePath();
    const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, radius);
    grad.addColorStop(0, 'rgba(99,102,241,0.70)');
    grad.addColorStop(1, 'rgba(236,72,153,0.25)');
    ctx.fillStyle   = grad;
    ctx.fill();
    ctx.strokeStyle = 'rgba(99,102,241,0.9)';
    ctx.lineWidth   = 2;
    ctx.stroke();

    // Vertex dots
    for (let i = 0; i < N; i++) {
      const a = start + i * step;
      const r = radius * (scores[i] / 8) * ease;
      const x = cx + r * Math.cos(a), y = cy + r * Math.sin(a);
      ctx.beginPath();
      ctx.arc(x, y, 4, 0, Math.PI * 2);
      ctx.fillStyle   = '#fff';
      ctx.shadowColor = DOMAINS[i].color;
      ctx.shadowBlur  = 8;
      ctx.fill();
      ctx.shadowBlur  = 0;
    }

    // Labels (fade in)
    if (progress > 0.65) {
      const alpha = Math.min(1, (progress - 0.65) / 0.35);
      ctx.globalAlpha = alpha;
      ctx.font        = 'bold 10px Inter, sans-serif';
      ctx.textAlign   = 'center';
      for (let i = 0; i < N; i++) {
        const a   = start + i * step;
        const lx  = cx + (radius + 36) * Math.cos(a);
        const ly  = cy + (radius + 36) * Math.sin(a);
        ctx.fillStyle = DOMAINS[i].color;
        labelLines[i].forEach((line, j) => {
          ctx.fillText(line, lx, ly + (j - (labelLines[i].length-1)/2) * 13);
        });
      }
      ctx.globalAlpha = 1;
    }

    if (progress < 1) requestAnimationFrame(animate);
  };
  requestAnimationFrame(animate);
}

/* ─────────────────────────────────────────────
   ACTIONS
───────────────────────────────────────────── */
function startAssessment() {
  state.screen = 'question';
  state.currentQ = 0;
  state.answers  = [];
  // Shuffle question order AND each question's option order
  state.shuffledQuestions = shuffle(QUESTIONS).map(q => ({
    ...q,
    options: shuffle(q.options),
  }));
  transitionTo(() => renderQuestion(0));
}

function selectOption(optIdx, score, domain) {
  if (state.animating) return;
  state.animating = true;

  const options = document.querySelectorAll('.option');
  const chosen  = options[optIdx];
  if (!chosen) return;

  document.getElementById('options-list')?.classList.add('disabled');
  chosen.classList.add('selected');
  setTimeout(() => chosen.classList.add('correct-flash'), 0);

  state.answers.push({ domain, score });

  setTimeout(() => {
    state.currentQ++;
    if (state.currentQ < state.shuffledQuestions.length) {
      transitionTo(() => renderQuestion(state.currentQ));
    } else {
      state.screen = 'results';
      transitionTo(() => renderResults());
    }
    state.animating = false;
  }, 420);
}

function retake() {
  resetState();
  transitionTo(() => renderIntro());
}

function transitionTo(renderFn) {
  const current = document.querySelector('.card.screen');
  if (current) {
    current.classList.add('exit');
    setTimeout(() => renderFn(), 260);
  } else {
    renderFn();
  }
}

