    `Growth Edge: ${DOMAINS[minIdx].icon} ${DOMAINS[minIdx].name}`,
    ``,
    `"${archetype.tagline}"`,
    ``,
    `Take the free 2-min assessment →`,
  ].join('\n');
  navigator.clipboard.writeText(text)
    .then(() => showToast('📋 Result copied to clipboard!'))
    .catch(() => showToast('📋 Copy your result from the page.'));
}

function shareLinkedIn() {
  const { archetype, pct } = computeResults();
  const text = encodeURIComponent(
    `Just took the AI-Native PM Readiness Assessment — I'm a "${archetype.name}" (${Math.round(pct*100)}%).\n\n"${archetype.tagline}"\n\nWorth 2 minutes if you're in product →`
  );
